{
  "name": "anmika-mahjong",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build && node -e \"require('fs').writeFileSync('dist/version.json', JSON.stringify({v: String(Date.now())}))\"",
    "preview": "vite preview",
    "server:ws": "node --import tsx server/ws_server.ts",
    "check": "svelte-check --tsconfig ./tsconfig.app.json && tsc -p tsconfig.node.json && tsc -p tsconfig.server.json",
    "test": "vitest run",
    "test:watch": "vitest",
    "pretest:e2e": "npm run build",
    "test:e2e": "ANMIKA_BASE_URL=http://127.0.0.1:8790 npx playwright test",
    "test:e2e:online": "node tools/run_online_e2e.mjs"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "@sveltejs/vite-plugin-svelte": "^7.0.0",
    "@tsconfig/svelte": "^5.0.8",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^24.12.2",
    "@vitest/ui": "^4.1.5",
    "playwright": "^1.60.0",
    "svelte": "^5.55.4",
    "svelte-check": "^4.4.6",
    "tsx": "^4.22.3",
    "typescript": "~6.0.2",
    "vite": "^8.0.10",
    "vitest": "^4.1.5"
  },
  "dependencies": {
    "@3d-dice/dice-box": "^1.1.4",
    "@kobalab/majiang-core": "^1.4.1",
    "@types/ws": "^8.18.1",
    "jsonwebtoken": "^9.0.3",
    "lottie-web": "^5.13.0",
    "ws": "^8.20.1"
  }
}
